{
    "name": "ilhamsyabani/laravel-volt-starter",
    "description": "A modern, MIT-licensed Laravel starter kit using Livewire Volt, Laravel Folio, and Tailwind CSS — 20+ custom UI components, theming system, and CRUD generators included.",
    "keywords": [
        "laravel",
        "livewire",
        "volt",
        "folio",
        "tailwind",
        "ui-kit",
        "starter-kit",
        "boilerplate",
        "theme",
        "blade",
        "php",
        "components",
        "crud",
        "admin",
        "dashboard"
    ],
    "homepage": "https://github.com/ilhamsyabani/laravel-volt-starter",
    "license": "MIT",
    "authors": [
        {
            "name": "Ilham Syabani",
            "email": "ilhamsyabani@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/ilhamsyabani/laravel-volt-starter/issues",
        "source": "https://github.com/ilhamsyabani/laravel-volt-starter"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "blade-ui-kit/blade-icons": "^1.6",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "livewire/livewire": "^4.0",
        "livewire/volt": "^1.10",
        "laravel/folio": "^1.0"
    },
    "suggest": {
        "livewire/livewire": "Required for Volt components (^4.0)",
        "livewire/volt": "Required for single-file Volt components (^1.10)",
        "laravel/folio": "Required for file-based routing (^1.0)",
        "codeat3/blade-phosphor-icons": "Required for icon components (^1.0)"
    },
    "autoload": {
        "psr-4": {
            "Ilhamsyabani\\VoltStarter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ilhamsyabani\\VoltStarter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "test-coverage": "./vendor/bin/pest --coverage",
        "format": "./vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ilhamsyabani\\VoltStarter\\VoltStarterServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
